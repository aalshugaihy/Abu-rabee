# Abu-Rabee root environment file (used by docker-compose.yml).
# Copy to `.env` and adjust as needed.

# JWT signing secret — MUST be a long random string in production.
JWT_SECRET=please-change-me-in-production

# Allowed origin for the API (must match where the client is actually served).
CLIENT_ORIGIN=http://localhost:8080

# How the client reaches the API at runtime. Inlined into the Vite bundle at
# build time — set this BEFORE `docker compose build` if you change it.
VITE_API_URL=http://localhost:4000

# Email transport: smtp | json | noop (json logs to stdout for local testing).
NODEMAIL_TRANSPORT=json

# Optional SMTP settings (only used when NODEMAIL_TRANSPORT=smtp).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Abu-Rabee <noreply@aburabee.local>
