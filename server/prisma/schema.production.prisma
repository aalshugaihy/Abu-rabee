// Abu-Rabee — production data model (PostgreSQL).
//
// Identical to schema.prisma except the datasource provider. Used by Render
// (or any other Postgres-backed deploy). The CI workflow `prepare:production`
// script copies this file over the dev SQLite schema before generating the
// client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("staff")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comments      Comment[]
  activity      ActivityLog[]
  refreshTokens RefreshToken[]
  savedViews    SavedView[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  page      String
  name      String
  filters   String   // JSON-encoded
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, page])
}

model Committee {
  id              String   @id
  name            String
  nameEn          String?
  type            String?
  scope           String
  department      String?
  sector          String?
  representative  String?
  head            String?
  organizer       String?
  members         Int?
  startDate       String?
  endDate         String?
  status          String
  active          Boolean  @default(true)
  confidentiality String?
  budget          Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks Task[]
}

model RequestRecord {
  id             String   @id
  name           String
  type           String?
  requester      String?
  classification String?
  priority       String?
  sector         String?
  department     String?
  purpose        String?
  direction      String?
  txnNumber      String?
  txnName        String?
  status         String
  owner          String?
  date           String?
  dueDate        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Task {
  id           String   @id
  title        String
  description  String?
  kind         String   // routine | team
  team         String?
  committeeId  String?
  department   String?
  assignee     String?
  priority     String
  status       String
  frequency    String?
  dueDate      String?
  lastRun      String?
  nextRun      String?
  progress     Int      @default(0)
  parentTaskId String?
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  committee Committee? @relation(fields: [committeeId], references: [id], onDelete: SetNull)
  parent    Task?      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children  Task[]     @relation("TaskSubtasks")

  blockedBy TaskDependency[] @relation("DependentTask")
  blocks    TaskDependency[] @relation("DependsOnTask")
}

model TaskDependency {
  id          String   @id @default(cuid())
  taskId      String
  dependsOnId String
  createdAt   DateTime @default(now())

  task      Task @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("DependsOnTask", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

model Comment {
  id         String   @id @default(cuid())
  entity     String
  entityId   String
  authorId   String?
  authorName String
  text       String
  at         DateTime @default(now())

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  entity   String
  action   String
  entityId String
  label    String?
  userId   String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
