{
  "name": "abu-rabee-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --skip-generate --accept-data-loss",
    "seed": "tsx src/seed.ts",
    "seed:prod": "node dist/seed.js",
    "prepare:production": "cp prisma/schema.production.prisma prisma/schema.prisma",
    "build:production": "npm run prepare:production && npx prisma generate && npm run build",
    "deploy:migrate": "npx prisma db push --skip-generate --accept-data-loss",
    "test:prepare": "rm -f prisma/test.db prisma/test.db-journal && DATABASE_URL=\"file:./test.db\" npx prisma db push --skip-generate --accept-data-loss",
    "test": "npm run test:prepare && vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.6",
    "socket.io": "^4.8.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
